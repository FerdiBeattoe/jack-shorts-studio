# Copy this file to .env and fill in the values. Never commit .env.

# fal.ai — used by `npm run generate-stills-lora` for production inference.
# Get a key at https://fal.ai/dashboard/keys
FAL_KEY=

# HuggingFace — used by hf-upload-dataset, hf-upload-lora, and both training
# paths (RunPod and Colab fallback). Token needs `write` scope.
# Get a token at https://huggingface.co/settings/tokens
HF_TOKEN=
HF_USERNAME=

# RunPod — used by `npm run train-lora-runpod` to spin up an RTX A5000 pod
# (Secure Cloud, ~$0.30/hr → ~$1 per training run), train SDXL LoRA, upload
# to HF, and tear down. Override the GPU with --gpu-type=... if you want.
# Get a key at https://www.runpod.io/console/user/settings (API Keys).
RUNPOD_API_KEY=

# Filled in after the Colab notebook finishes training and uploads the LoRA.
# Example: https://huggingface.co/your-name/jack-saas-lora-v1/resolve/main/jack-lora.safetensors
LORA_URL=
